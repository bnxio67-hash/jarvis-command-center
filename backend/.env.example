ENV=development
DEBUG=true

# Muss auf dem Handy im Header X-API-Key mitgeschickt werden
API_KEY=setze-hier-einen-langen-zufaelligen-schluessel

# Anthropic (KI-Gehirn / Tool-Calling)
ANTHROPIC_API_KEY=
LLM_MODEL=claude-sonnet-4-6

# Websuche (z.B. Brave Search API)
SEARCH_API_KEY=

# Satelliten-TLE-Daten (n2yo.com o.ä.), optional serverseitig
N2YO_API_KEY=

TELEMETRY_INTERVAL_SECONDS=1.0
